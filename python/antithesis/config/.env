# This environment file is loaded during docker-compose `up` and `down`.
# Variables defined here are only used to expand docker-compose placeholders.
# Not passed into the containers environment.

# Defaults (used in local build)
IMAGES_PREFIX=tutorial
IMAGES_TAG=local

# N.B. When building and publishing images via GH Workflow, values for the
# IMAGES_PREFIX and IMAGES_TAG variables are appended below.
# And override the defaults above.
